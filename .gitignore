# ================================================================
# ROOT .gitignore — Lexioai Project-Wide
# ================================================================
# Prevents sensitive files, dependencies, and build artifacts
# from being committed to the repository
# ================================================================

# ================================================================
# ENVIRONMENT VARIABLES (SECRETS)
# ================================================================
.env
.env.local
.env.*.local
.env.production
.env.production.local
.env.development
.env.development.local
.env.test
.env.test.local

# ================================================================
# NODE MODULES & DEPENDENCIES
# ================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnp
.pnp.js

# ================================================================
# BUILD & DIST OUTPUTS
# ================================================================

dist-ssr/
build/
coverage/
.nuxt/
out/
.next/

# ================================================================
# IDE & EDITOR FILES
# ================================================================
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
.idea/
.DS_Store
*.swp
*.swo
*~
.sublime-*
*.code-workspace

# ================================================================
# OS FILES
# ================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ================================================================
# LOGS & TEMPORARY FILES
# ================================================================
*.log
logs/
*.pid
*.seed
*.pid.lock
tmp/
temp/

# ================================================================
# DATABASE FILES (Local)
# ================================================================
*.db
*.sqlite
*.sqlite3
.mongodb/
mongodb_data/

# ================================================================
# DEPLOYMENT & CI/CD
# ================================================================
.vercel/
.netlify/
.env.production
aws-exports.js
amplify-exports.ts

# ================================================================
# SECURITY FILES (Private Keys, Certs)
# ================================================================
*.pem
*.key
*.cert
*.crt
*.p12
*.pfx
private/
secrets/

# ================================================================
# OS-SPECIFIC BACKUP & RECOVERY
# ================================================================
.directory
.trash/
.config/

# ================================================================
# PACKAGE MANAGER LOCK FILES (Optional - Uncomment if needed)
# ================================================================
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ================================================================
# MISCELLANEOUS
# ================================================================
.turbo/
dist-types/
*.tgz

# ================================================================
# PROJECT-SPECIFIC
# ================================================================
uploads/
/storage/
.cache/

# plan files 
plan.txt
plan.md
